# IF.data API
BC_IFDATA_BASE_URL=https://olinda.bcb.gov.br/olinda/servico/IFDATA/versao/v1/odata
BC_IFDATA_TIMEOUT_SEC=60

# DuckDB
BC_DUCKDB_PATH=data/bc_dashboard.duckdb

# Data range (number of quarterly periods, 20 = 5 years)
BC_HISTORY_QUARTERS=20

# Dashboard
BC_DASH_DEBUG=true
BC_DASH_HOST=0.0.0.0
BC_DASH_PORT=8050
